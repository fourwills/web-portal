# API base URL — see CONFIGURATION.md §1
# Local: /api_dnl/v1 (vite proxy) or full URL | Vercel: /api_dnl/v1 + vercel.json | Hostverge: .env.hostverge
VITE_API_BASE_URL=/api_dnl/v1

# Dev mock login (no API call). Set to false when using real credentials.
VITE_DEV_MOCK_AUTH=false

# Platform IPs — Account → "Our platform IPs". See CONFIGURATION.md §2a
# Comma-separated, optional :port (default 5060). Client trunk IPs: Trunks → Edit IPs (not here).
VITE_PLATFORM_IPS=163.172.118.64

# Test credentials (see TEST_CREDENTIALS.md) — local only
VITE_TEST_EMAIL_OR_NAME=
VITE_TEST_PASSWORD=
