# API base URL — change this to point at any server without editing code
VITE_API_BASE_URL=https://portal.incorpus.in/api_dnl/v1

# Dev mock login (no API call). Set to false when using real credentials.
VITE_DEV_MOCK_AUTH=false

# Platform IPs shown to clients (not from API). Comma-separated, optional port.
# Example: 163.172.118.64 or 163.172.118.64:5060
VITE_PLATFORM_IPS=163.172.118.64

# Test credentials (see TEST_CREDENTIALS.md) — local only
VITE_TEST_EMAIL_OR_NAME=
VITE_TEST_PASSWORD=
